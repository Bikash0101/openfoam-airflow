FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}

solvers
{
    // The "(p|pFinal)" syntax covers both requirements
    "(p|pFinal)"
    {
        solver          GAMG;
        tolerance       1e-6;
        relTol          0.01;
        smoother        GaussSeidel;
    }

    // This covers U, k, omega AND their Final versions
    "(U|k|omega|UFinal|kFinal|omegaFinal)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
    }
}


PIMPLE
{
    nOuterCorrectors 2;
    nCorrectors      2;
    pRefPoint (0 0 0);
    pRefValue 0;
}