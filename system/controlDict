FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

// Ensure you are using the transient version of the solver
application     foamRun;
solver          incompressibleFluid;
simulationType  transient; // Mandatory for startup behavior

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         10;        // Total seconds to simulate

// Time step: Must be small enough for stability (CFL < 1)
// For sudden fan startup at 2 m/s: CFL = u*dt/dx < 1
// With cell size ~0.15m: dt < 0.075s. Use 0.01s for safety.
deltaT          0.05;     

writeControl    adjustableRunTime;
writeInterval   0.1;       // Save data every 0.1s with smaller time steps

purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;
timeFormat      general;
timePrecision   6;

// Useful for debugging startup
runTimeModifiable yes;

// Allow OpenFOAM to automatically adjust deltaT for speed/stability
adjustTimeStep  yes;
maxCo           0.7;       // Conservative for transient startup with strong inlet

// ========================================================================
// FUNCTION OBJECTS: Monitor fan jet development
// ========================================================================

functions
{
    // Probes: Sample velocity at key locations downstream of fan
    probes
    {
        type            probes;
        libs            ("libsampling.so");
        writeControl    timeStep;
        writeInterval   1;              // Log every time step
        
        probeLocations
        (
            (2.5 0.9 0.9)           // 1m downstream of fan (jet centerline)
            (2.5 1.1 0.9)           // 0.2m off-center
            (2.5 0.7 0.9)           // 0.2m off-center
            (3.0 0.9 0.9)           // 1.5m downstream
            (4.0 0.9 0.9)           // 2.5m downstream
        );
        
        fields  (U p);              // Monitor velocity and pressure
    }

    // Residuals: Track convergence of pressure-velocity system
    residuals
    {
        type            residuals;
        libs            ("libfieldFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
        fields          (p U);
    }
}

