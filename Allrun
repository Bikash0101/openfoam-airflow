#!/bin/sh
cd ${0%/*} || exit 1    # Run from this directory

# Source tutorial run functions
. $WM_PROJECT_DIR/bin/tools/RunFunctions

echo "=========================================="
echo "Stand Fan Office Airflow Simulation"
echo "OpenFOAM v2412 - incompressibleFluid"
echo "=========================================="
echo ""

# Step 1: Generate base hexahedral mesh
echo "Step 1/5: Generating base mesh..."
runApplication blockMesh

# Step 2: Create fan disc surface as searchableDisk faceSet
echo "Step 2/5: Creating fan disc geometry..."
runApplication topoSet

# Step 3: Convert faceZone to cyclic boundary patch
echo "Step 3/5: Creating cyclic patch for fan..."
runApplication createPatch -overwrite

# Step 4: Verify mesh topology
echo "Step 4/5: Checking mesh quality..."
runApplication checkMesh -allTopology

# Step 5: Run transient incompressible fluid simulation
echo "Step 5/5: Running transient CFD simulation..."
echo "  - Solver: incompressibleFluid"
echo "  - Algorithm: PIMPLE (3 outer loops)"
echo "  - Duration: 10 seconds (transient)"
echo "  - Time step: 0.05 seconds"
echo ""
runApplication foamRun

# Post-processing: Extract probe data
echo ""
echo "=========================================="
echo "Simulation Complete!"
echo "=========================================="
echo ""
echo "Probe data available at:"
echo "  - postProcessing/probes/0/U"
echo "  - postProcessing/probes/0/p"
echo ""
echo "Convergence history:"
echo "  - postProcessing/residuals/0/residuals.dat"
echo ""
echo "To visualize results:"
echo "  paraFoam -builtin"
echo ""

#------------------------------------------------------------------------------
