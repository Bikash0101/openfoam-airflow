FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 1e-05;

boundaryField
{
    floor
    {
        type            nutkWallFunction;
        value           uniform 1e-05;
    }

    ceiling
    {
        type            nutkWallFunction;
        value           uniform 1e-05;
    }

    walls
    {
        type            nutkWallFunction;
        value           uniform 1e-05;
    }

    partition
    {
        type            nutkWallFunction;
        value           uniform 1e-05;
    }

    fan_inlet
    {
        type            fixedValue;
        value           uniform 1e-05;
    }

    fan_outlet
    {
        type            zeroGradient;
    }
}
