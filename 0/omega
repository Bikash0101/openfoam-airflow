FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    floor
    {
        type            omegaWallFunction;
        value           uniform 1;
    }

    ceiling
    {
        type            omegaWallFunction;
        value           uniform 1;
    }

    walls
    {
        type            omegaWallFunction;
        value           uniform 1;
    }

    partition
    {
        type            omegaWallFunction;
        value           uniform 1;
    }
}
