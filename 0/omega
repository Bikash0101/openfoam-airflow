FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 0.1;

boundaryField
{
    floor
    {
        type            omegaWallFunction;
        value           uniform 0.1;
    }

    ceiling
    {
        type            omegaWallFunction;
        value           uniform 0.1;
    }

    walls
    {
        type            omegaWallFunction;
        value           uniform 0.1;
    }

    partition
    {
        type            omegaWallFunction;
        value           uniform 0.1;
    }

    fan_inlet
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    0.1;
        value           uniform 0.1;
    }

    fan_outlet
    {
        type            zeroGradient;
    }
}
