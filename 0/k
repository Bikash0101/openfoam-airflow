FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    floor
    {
        type            kqRWallFunction;
        value           uniform 0.01;
    }

    ceiling
    {
        type            kqRWallFunction;
        value           uniform 0.01;
    }

    walls
    {
        type            kqRWallFunction;
        value           uniform 0.01;
    }

    partition
    {
        type            kqRWallFunction;
        value           uniform 0.01;
    }
}
